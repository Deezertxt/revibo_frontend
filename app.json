{
  "expo": {
    "name": "Revibo",
    "slug": "revibo_frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/crnjmrdiconPNG.png",
    "scheme": "revibofrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sixsevempm.revibo",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
            "apiKey": "AIzaSyChO-LOL51YwtR8q-fhp3U9xEBuDf5UslA"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/RATCHETSPLASHPNG.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#7C63E8",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53678461-c8cc-4b61-a4f8-423abe5c7c2b"
      }
    },
    "owner": "maudiazarz04"
  }
}
