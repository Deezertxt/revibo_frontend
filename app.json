{
  "expo": {
    "name": "Revibo",
    "slug": "revibo_frontend",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo2redim.png",
    "notification": {
      "icon": "./assets/images/notilogoREDIM.png",
      "color": "#5B3FD9"
    },
    "scheme": "revibofrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo2redimsin.png",
        "backgroundColor": "#1E1E2E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sixsevempm.revibo",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyChO-LOL51YwtR8q-fhp3U9xEBuDf5UslA"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo2redim.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo2redimsin.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E1E2E"
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53678461-c8cc-4b61-a4f8-423abe5c7c2b"
      }
    },
    "owner": "maudiazarz04"
  }
}